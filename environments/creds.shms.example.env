# Optional migration fallback for startup secrets.
# Nautobot can load these keys from SHMS_STARTUP_SECRETS_VAULT_PATH when
# creds.shms.env is absent; keep this file only for explicit rollback/fallback.
NAUTOBOT_CREATE_SUPERUSER=true
NAUTOBOT_DB_PASSWORD=changeme
NAUTOBOT_NAPALM_USERNAME=
NAUTOBOT_NAPALM_PASSWORD=
NAUTOBOT_REDIS_PASSWORD=changeme
NAUTOBOT_SECRET_KEY=changeme
NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@shms.local
NAUTOBOT_SUPERUSER_PASSWORD=changeme

# Explicit legacy Vault token fallback during the mTLS migration.
# Prefer VAULT_AUTH_METHOD=cert with client cert/key settings in local.shms.env
# for migrated workloads.
HASHICORP_VAULT_TOKEN=

POSTGRES_PASSWORD=${NAUTOBOT_DB_PASSWORD}
PGPASSWORD=${NAUTOBOT_DB_PASSWORD}
